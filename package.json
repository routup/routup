{
    "name": "routup",
    "version": "4.1.0",
    "type": "module",
    "description": "Routup is a minimalistic http based routing framework.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist/"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build": "tsdown",
        "test": "vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage",
        "lint": "eslint",
        "lint:fix": "npm run lint -- --fix",
        "prepare": "husky",
        "prepublishOnly": "npm run build"
    },
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "license": "MIT",
    "keywords": [
        "api",
        "rest",
        "http",
        "router",
        "api-router",
        "route",
        "routing"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/routup/routup.git"
    },
    "bugs": {
        "url": "https://github.com/routup/routup/issues"
    },
    "homepage": "https://github.com/routup/routup#readme",
    "dependencies": {
        "@ebec/http": "^2.3.0",
        "buffer": "^6.0.3",
        "mime-explorer": "^1.1.0",
        "negotiator": "^1.0.0",
        "path-to-regexp": "^8.4.2",
        "proxy-addr": "^2.0.7",
        "readable-stream": "^4.7.0",
        "smob": "^1.5.0",
        "uncrypto": "^0.1.3"
    },
    "devDependencies": {
        "@tada5hi/commitlint-config": "^1.3.1",
        "@tada5hi/eslint-config": "^2.3.0",
        "@tada5hi/tsconfig": "^0.7.2",
        "@types/negotiator": "^0.6.4",
        "@types/node": "^25.5.2",
        "@types/proxy-addr": "^2.0.3",
        "@types/readable-stream": "^4.0.23",
        "@types/supertest": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.2",
        "eslint": "^10.1.0",
        "husky": "^9.1.7",
        "supertest": "^7.2.2",
        "tsdown": "^0.21.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2",
        "vitest": "^4.1.1"
    }
}
